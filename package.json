{
  "name": "feathers-graph-populate",
  "description": "Add lightning fast, GraphQL-like populates to your FeathersJS API.",
  "version": "5.0.1",
  "homepage": "https://feathers-graph-populate.netlify.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/marshallswain/feathers-graph-populate"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "keywords": [
    "feathers",
    "feathers.js",
    "feathers-plugin",
    "hooks",
    "populate"
  ],
  "author": {
    "name": "Marshall Thompson",
    "email": "marshall@creativeideal.net"
  },
  "contributors": [],
  "bugs": {},
  "files": [
    "LICENSE",
    "README.md",
    "src/**",
    "dist/**"
  ],
  "engines": {
    "node": ">= 22"
  },
  "scripts": {
    "compile": "shx rm -rf dist/ && tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run lint && npm run test && npm run compile",
    "version": "npm run compile",
    "release": "np",
    "lint": "eslint",
    "test": "vitest run",
    "vitest": "vitest",
    "coverage": "vitest run --coverage",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "peerDependencies": {
    "@feathersjs/feathers": "^5.0.0"
  },
  "dependencies": {
    "@feathersjs/commons": "^5.0.44",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@feathers-community/eslint-config": "^0.0.10",
    "@feathersjs/errors": "^5.0.44",
    "@feathersjs/feathers": "^5.0.44",
    "@feathersjs/memory": "^5.0.44",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.38.0",
    "np": "^11.2.0",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  }
}
